@model IInvoiceManagementSystem.DTOs.UpdateInvoiceDto

@{
    ViewData["Title"] = "Edit Invoice";
}

<h1>Edit Invoice</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" id="editForm">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="CustomerName" class="control-label"></label>
                <input asp-for="CustomerName" class="form-control" />
                <span asp-validation-for="CustomerName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CustomerEmail" class="control-label"></label>
                <input asp-for="CustomerEmail" class="form-control" type="email" />
                <span asp-validation-for="CustomerEmail" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="InvoiceDate" class="control-label"></label>
                <input asp-for="InvoiceDate" class="form-control" type="date" />
                <span asp-validation-for="InvoiceDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DueDate" class="control-label"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Tax" class="control-label"></label>
                <input asp-for="Tax" class="form-control" type="number" step="0.1" min="0" max="100" />
                <span asp-validation-for="Tax" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Draft">Draft</option>
                    <option value="Sent">Sent</option>
                    <option value="Paid">Paid</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

<!-- JavaScript to handle form submission with delay -->
<script>
    document.getElementById('editForm').addEventListener('submit', function(e) {
        e.preventDefault(); // Stop normal form submission

        var form = this;
        var formData = new FormData(form);
        var invoiceId = formData.get('Id');

        fetch('/Invoices/Edit/' + invoiceId, {
            method: 'POST',
            body: formData
        })
        .then(response => {
            if (response.redirected) {
                // Wait 1.5 seconds to see the toast before redirecting
                setTimeout(function() {
                    window.location.href = response.url;
                }, 3000); // 3 seconds delay
            }
        })
        .catch(error => console.error('Error:', error));
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // SignalR connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.start().catch(err => console.error(err));

        connection.on("ReceiveNotification", function(title, message, timestamp) {
            // Create toast
            const toast = document.createElement('div');
            toast.style.position = 'fixed';
            toast.style.bottom = '20px';
            toast.style.right = '20px';
            toast.style.backgroundColor = '#333';
            toast.style.color = 'white';
            toast.style.padding = '15px 20px';
            toast.style.borderRadius = '5px';
            toast.style.boxShadow = '0 4px 12px rgba(0,0,0,0.3)';
            toast.style.zIndex = '9999';
            toast.style.minWidth = '300px';
            toast.style.animation = 'slideIn 0.5s';

            toast.innerHTML = `
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <strong>${title}</strong>
                    <small>${timestamp}</small>
                </div>
                <div>${message}</div>
                <button onclick="this.parentElement.remove()" style="position: absolute; top: 5px; right: 10px;">×</button>
            `;

            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        });

        // Add animation
        const style = document.createElement('style');
        style.innerHTML = `
            @@keyframes slideIn {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
        `;
        document.head.appendChild(style);
    </script>
}