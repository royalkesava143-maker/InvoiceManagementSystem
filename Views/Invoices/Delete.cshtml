@model IInvoiceManagementSystem.DTOs.InvoiceDto

@{
    ViewData["Title"] = "Delete Invoice";
}

<h1>Delete Invoice</h1>

<h3>Are you sure you want to delete this invoice?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Invoice Number
        </dt>
        <dd class="col-sm-10">
            @Model.InvoiceNumber
        </dd>

        <dt class="col-sm-2">
            Customer Name
        </dt>
        <dd class="col-sm-10">
            @Model.CustomerName
        </dd>

        <dt class="col-sm-2">
            Customer Email
        </dt>
        <dd class="col-sm-10">
            @Model.CustomerEmail
        </dd>

        <dt class="col-sm-2">
            Invoice Date
        </dt>
        <dd class="col-sm-10">
            @Model.InvoiceDate.ToString("yyyy-MM-dd")
        </dd>

        <dt class="col-sm-2">
            Due Date
        </dt>
        <dd class="col-sm-10">
            @Model.DueDate.ToString("yyyy-MM-dd")
        </dd>

        <dt class="col-sm-2">
            Amount
        </dt>
        <dd class="col-sm-10">
            @Model.Amount.ToString("C")
        </dd>

        <dt class="col-sm-2">
            Tax (%)
        </dt>
        <dd class="col-sm-10">
            @Model.Tax
        </dd>

        <dt class="col-sm-2">
            Total Amount
        </dt>
        <dd class="col-sm-10">
            @Model.TotalAmount.ToString("C")
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            <span class="badge @(Model.Status == "Paid" ? "bg-success" : Model.Status == "Sent" ? "bg-primary" : "bg-secondary")">
                @Model.Status
            </span>
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>