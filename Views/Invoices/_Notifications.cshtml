@model IEnumerable<IInvoiceManagementSystem.DTOs.NotificationDto>

<div class="card" style="width: 300px;">
    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
        <span>Notifications</span>
        <button type="button" class="btn-close btn-close-white" onclick="document.getElementById('notificationContainer').style.display='none'"></button>
    </div>
    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
        @if (Model.Any())
        {
            @foreach (var notification in Model)
            {
                <div class="alert alert-info alert-dismissible fade show mb-2" role="alert">
                    <strong>@notification.Title</strong>
                    <small class="d-block text-muted">@notification.Message</small>
                    <small class="d-block text-muted">@notification.CreatedDate.ToString("hh:mm:ss tt")</small>
                    <button type="button" class="btn-close" onclick="markAsRead(@notification.Id)"></button>
                </div>
            }
        }
        else
        {
            <p class="text-muted mb-0">No unread notifications</p>
        }
    </div>
</div>

<script>
    function markAsRead(id) {
        fetch('/Invoices/MarkAsRead/' + id, {
            method: 'POST'
        }).then(() => {
            showNotifications(); // Refresh the notifications list
            location.reload(); // Refresh to update unread count
        });
    }
</script>